<!DOCTYPE html>
<html>
<body>

<input id="pesel" placeholder="Podaj PESEL">
<button onclick="sprawdz()">Sprawdź</button>

<p id="wynik"></p>

<script>

function sprawdz(){

let pesel = document.getElementById("pesel").value;
let wynik = document.getElementById("wynik");

if(pesel.length == 11){
wynik.innerHTML = maskuj(pesel);
wynik.style.color = "green";
}else{
wynik.innerHTML = "Błąd";
wynik.style.color = "red";
}

}

function maskuj(pesel){

let ostatnie = pesel.slice(-4);

return "*******" + ostatnie;

}

</script>

</body>
</html>


<!DOCTYPE html>
<html>
<body>

<script>

// klasa SlugGenerator
class SlugGenerator{

generuj(tytul){

return tytul
.toLowerCase()
.replace(/[^\w\s]/g,"")
.replace(/\s+/g,"-");

}

}

let slug = new SlugGenerator();
console.log(slug.generuj("Co to jest OOP?"));


// klasa Analizator
class Analizator{

liczSamogloski(tekst){

let sam = "aeiouy";
let licznik = 0;

for(let i=0;i<tekst.length;i++){

if(sam.includes(tekst[i].toLowerCase())){
licznik++;
}

}

return licznik;

}

}

let a = new Analizator();
console.log("Samogłoski:", a.liczSamogloski("Programowanie"));


// odwracanie stringa
function odwroc(str){

let wynik = "";

for(let i=str.length-1;i>=0;i--){
wynik += str[i];
}

return wynik;

}

console.log(odwroc("ABC"));

</script>

</body>
</html>








