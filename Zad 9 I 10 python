def wieksza(x, y):
    if x > y:
        return x
    return y

# Część sprawdzająca (zgodnie z przykładem w treści zadania)
x = int(input("proszę wpisać liczbę x: "))
y = int(input("proszę wpisać liczbę y: "))

wynik = wieksza(x, y)
print("Liczba większa to", wynik)
