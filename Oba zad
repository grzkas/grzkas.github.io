<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 2</title>
</head>
<body>

<input type="text" id="tekst">
<p id="licznik"></p>

<input type="password" id="haslo">

<select id="kolor">
  <option value="">Wybierz kolor</option>
  <option value="red">Czerwony</option>
  <option value="green">Zielony</option>
  <option value="blue">Niebieski</option>
</select>

<script>
// input – liczba znaków
document.getElementById("tekst").addEventListener("input", function() {
  document.getElementById("licznik").textContent = this.value.length;
});

// blur – sprawdzanie hasła
document.getElementById("haslo").addEventListener("blur", function() {
  if (this.value.length < 8) {
    this.style.border = "2px solid red";
  } else {
    this.style.border = "";
  }
});

// select – zmiana tła
document.getElementById("kolor").addEventListener("change", function() {
  document.body.style.background = this.value;
});
</script>

</body>
</html>


<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Poziom 3</title>
</head>
<body>

<form id="form">
  <input type="text" id="email">
  <input type="password" id="haslo1">
  <input type="password" id="haslo2">
  <button type="submit">Wyślij</button>
</form>

<p id="komunikat"></p>

<script>
document.getElementById("form").addEventListener("submit", function(e) {
  e.preventDefault();

  const email = document.getElementById("email").value;
  const haslo1 = document.getElementById("haslo1").value;
  const haslo2 = document.getElementById("haslo2").value;
  const komunikat = document.getElementById("komunikat");

  if (haslo1 !== haslo2) {
    komunikat.textContent = "Hasła nie są zgodne";
    komunikat.style.color = "red";
  }

  if (!email.includes("@")) {
    komunikat.textContent = "Niepoprawny e-mail";
    komunikat.style.color = "red";
  }
});
</script>

</body>
</html>
